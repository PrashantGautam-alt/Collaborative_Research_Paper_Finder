# Copy this file, rename the copy to .env, then fill in your real keys.
# NEVER commit .env to GitHub — it is already in .gitignore.
# Get Gemini key at:            https://aistudio.google.com/app/apikey
# Get Semantic Scholar key at:  https://www.semanticscholar.org/product/api

GEMINI_API_KEY=your_gemini_key_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here
